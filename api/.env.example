# AssistLens API environment.
PORT=8080
NODE_ENV=development

JWT_SECRET=dev-jwt-secret
INVITE_SECRET=dev-invite-secret

AGENT_EMAIL=agent@assistlens.dev
AGENT_PASSWORD=demo-agent-pass

ADMIN_EMAIL=admin@assistlens.dev
ADMIN_PASSWORD=demo-admin-pass

# ── Postgres (Supabase) ───────────────────────────────────────────────────
# Use the Supabase "Connection string" (Session pooler, port 5432/6543).
# Managed Postgres requires TLS; the API auto-enables SSL for non-local hosts.
# Example: postgres://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# ── LiveKit (self-hosted SFU container) ────────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevse
# Server-side URL the API uses for token minting / room admin / egress.
LIVEKIT_URL=http://localhost:7880
# Public ws(s) URL the browser connects to (self-hosted LiveKit host).
PUBLIC_LIVEKIT_URL=ws://localhost:7880

# Origin of the web app (used for CORS in production + building invite links).
PUBLIC_WEB_ORIGIN=http://localhost:5173

# ── Recording (optional bonus) — only needed when the recording stack runs ─
S3_ENDPOINT=http://localhost:9000
# URL Egress (in Docker) uses to upload recordings — use the MinIO service name.
S3_EGRESS_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=assistlens
S3_SECRET_KEY=assistlens-minio
S3_REGION=us-east-1
MINIO_BUCKET=recordings
FILES_BUCKET=files

RECONNECT_GRACE_SECONDS=30
INVITE_TTL_SECONDS=86400
