# ─────────────────────────────────────────────────────────────
# AssistLens environment (shared reference). Copy to .env for local
# docker (LiveKit) and mirror these into your Railway / Vercel / Render
# service settings for production.
# ─────────────────────────────────────────────────────────────

# ── Secrets (CHANGE ALL OF THESE) ─────────────────────────────
JWT_SECRET=change-me-super-secret-jwt-key
INVITE_SECRET=change-me-super-secret-invite-key

# Seed agent account (created on first boot)
AGENT_EMAIL=agent@assistlens.dev
AGENT_PASSWORD=demo-agent-pass

# ── Postgres (Supabase, managed) ──────────────────────────────
# Supabase → Project Settings → Database → Connection string (URI).
# SSL is auto-enabled for non-local hosts.
DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── LiveKit (self-hosted SFU container) ───────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevse
# Server-side URL the API uses (internal/private URL of the LiveKit service).
LIVEKIT_URL=http://localhost:7880
# Public ws(s) URL the browser connects to (your LiveKit host; wss in prod).
PUBLIC_LIVEKIT_URL=ws://localhost:7880

# Public origin of the web app (CORS + invite link base).
PUBLIC_WEB_ORIGIN=http://localhost:5173

# Reconnect grace window + invite token lifetime (seconds)
RECONNECT_GRACE_SECONDS=30
INVITE_TTL_SECONDS=86400

# ── Recording (optional bonus; only when the recording stack runs) ─────────
MINIO_BUCKET=recordings
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=assistlens
S3_SECRET_KEY=assistlens-minio
S3_REGION=us-east-1

# ── Web build-time (Vercel / Railway) ─────────────────────────
# Full public URL of the API (e.g. https://assistlens-api.up.railway.app/api).
# Locally this defaults to /api (Vite proxies to the API).
VITE_API_BASE=/api
